
<%-layout("/layouts/boilerplate.ejs")%>


    <div class="row">
        <div class="col-8 offset-2">
            <h3>Edit Listing</h3>
            <br>
            <!--if we want to send files(image upload feature) then we need to set enctype = multipart/form-data-->
            <form action="/listings/<%=card._id%>?_method=PUT" method="post" class="needs-validation" novalidate enctype="multipart/form-data" >
                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <input type="text" placeholder="Ex. My House" name="listing[title]" id="title" value = "<%=card.title%>" class="form-control"
                        required>
                    <!-- example of form validation  -->
                    <div class="valid-feedback"> 
                    Looks good!
                    </div>
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea placeholder="Ex. Newly build ,fully furnitured" name="listing[description]" rows="5"
                        cols="20" class="form-control" id="description" required> <%=card.description%></textarea>
                    <div class="valid-feedback"> 
                    Looks good!
                    </div>
                </div>
                
                <div class="mb-3">
                    <label for="image" class="form-label">Upload image</label>
                    <input type="file" name="listing[image]" value = "<%=card.image.url%>" id="image"
                        class="form-control">
                    <div class="invalid-feedback">
                    Please upload an image
                    </div>
                </div>
                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="price" class="form-label">Price</label>
                        <input type="number" placeholder="Ex. 5000" name="listing[price]" value = "<%=card.price%>" class="form-control"
                            id="price" required>
                        <div class="invalid-feedback">
                        Please enter price.
                        </div>
                    </div>


                    <div class="mb-3 col-md-8">
                        <label for="country" class="form-label">Country</label>
                        <input type="text" placeholder="Ex. India" name="listing[country]" value = "<%=card.country%>" id="country"
                            class="form-control" required>
                        <div class="invalid-feedback">
                        Please enter country.
                        </div>

                    </div>
                </div>

                <% 
                    const loc = (typeof card.location === 'object' && card.location !== null) ? card.location : {};
                    const legacyLoc = (typeof card.location === 'string') ? card.location : '';
                %>
                <h5 class="mt-4 mb-3">Address</h5>
                <div class="mb-3">
                    <label for="pincode" class="form-label">Pincode</label>
                    <input type="text" placeholder="Ex. 110067" name="listing[location][pincode]" id="pincode"
                        class="form-control" value="<%= loc.pincode || '' %>" inputmode="numeric" pattern="[0-9]{6}" maxlength="10" required>
                    <div class="invalid-feedback">
                        Please enter a valid pincode.
                    </div>
                </div>
                <div class="mb-3">
                    <label for="state" class="form-label">State</label>
                    <input type="text" placeholder="Ex. Delhi" name="listing[location][state]" id="state"
                        class="form-control" value="<%= loc.state || '' %>" required>
                    <div class="invalid-feedback">
                        Please enter state.
                    </div>
                </div>
                <div class="mb-3">
                    <label for="city" class="form-label">City</label>
                    <input type="text" placeholder="Ex. New Delhi" name="listing[location][city]" id="city"
                        class="form-control" value="<%= loc.city || '' %>" required>
                    <div class="invalid-feedback">
                        Please enter city.
                    </div>
                </div>
                <div class="mb-3">
                    <label for="area" class="form-label">Area</label>
                    <input type="text" placeholder="Ex. Munirka" name="listing[location][area]" id="area"
                        class="form-control" value="<%= loc.area || legacyLoc %>" required>
                    <div class="invalid-feedback">
                        Please enter area / locality.
                    </div>
                </div>

                <%# Preserve fields required by Joi on PUT (same as create form) %>
                <input type="hidden" name="listing[gender]" value="<%= card.gender || 'unisex' %>">
                <% if (Array.isArray(card.amenities)) { card.amenities.forEach(function(a) { %>
                <input type="hidden" name="listing[amenities]" value="<%= a %>">
                <% }); } %>
                <% if (Array.isArray(card.services)) { card.services.forEach(function(s) { %>
                <input type="hidden" name="listing[services]" value="<%= s %>">
                <% }); } %>

                <button type="submit" class="btn btn-dark add">Edit List</button>
                <br><br>
            </form>
        </div>
    </div>
    <script src="/js/pincode-autofill.js"></script>